\begin_inset Formula $d$
\end_inset

 
\end_layout

\begin_layout Standard
Formally:
 
\begin_inset Formula 
\[
(A,B,C)_{t+1}=\Phi(A,B,C,d).
\]

\end_inset


\end_layout

