\begin_layout Section*
8.
 Interpretation
\end_layout

\begin_layout Standard
The Parasite machine demonstrates:
 
\end_layout

\begin_layout Itemize
\begin_inset Argument 1
status collapsed

\begin_layout Plain Layout
leftmargin=2em
\end_layout

\end_inset

structure emerges from relational transformation,
 
\end_layout

\begin_layout Itemize
noise and entity are phase regimes,
 
\end_layout

\begin_layout Itemize
roles are positional,
 not intrinsic,
 
\end_layout

\begin_layout Itemize
ontology is not presupposed but produced.
 
\end_layout

\begin_layout Section*
9.
 Final statement
\end_layout

\begin_layout Standard
A system of relations,
 perturbed and stabilized by a third term,
 can generate entities and structure without recourse to conserved substance or fixed ontology.
\end_layout

