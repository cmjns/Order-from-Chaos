\begin_inset Formula 
\[
B=\mathcal{F}_{B},\qquad C=\mathcal{F}_{C}
\]

\end_inset


\end_layout

\begin_layout Paragraph
Narrative
\end_layout

\begin_layout Standard
A,
 B,
 and C are no longer merely positions in a simplex.
 They are internally active regions.
\end_layout

\begin_layout Standard
