\begin_layout Section*
4. Transformation of relations
\end_layout

\begin_layout Standard
Let 
\begin_inset Formula $R(A,B)$
\end_inset

 denote the baseline relation strength. Define a transformation: 
\begin_inset Formula \[
R'(A,B) = T(R(A,B), C, k).
\]
\end_inset

Two cases: 
\begin_inset Formula \begin{align*}
\text{Noise: } & R' = R + \eta(C)\,k \\
\text{Metastability: } & R' = R + \alpha \, C \, k
\end{align*}
\end_inset

where 
\begin_inset Formula $\eta$
\end_inset

 is a stochastic perturbation and 
\begin_inset Formula $\alpha$
\end_inset

 a scaling constant.
\end_layout

\begin_layout Section*
5. Role permutation
\end_layout

\begin_layout Standard
Positions are not fixed. Let 
\begin_inset Formula $\sigma$
\end_inset

 be a permutation: 
\begin_inset Formula \[
(A,B,C) \mapsto \sigma(A,B,C).
\]
\end_inset

This encodes sudden reassignment of roles.
\end_layout

